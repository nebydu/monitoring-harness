{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "cmd.exe",
            "args": [
              "/c",
              "${CLAUDE_PLUGIN_ROOT}/hooks/git-bash.cmd",
              "${CLAUDE_PLUGIN_ROOT}/hooks/write-guard-entry.sh",
              "${CLAUDE_PROJECT_DIR}/.claude/write-guard.profile"
            ]
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "cmd.exe",
            "args": [
              "/c",
              "${CLAUDE_PLUGIN_ROOT}/hooks/git-bash.cmd",
              "${CLAUDE_PLUGIN_ROOT}/hooks/codex-gate-entry.sh",
              "${CLAUDE_PROJECT_DIR}/.claude/codex-gate.profile"
            ]
          }
        ]
      }
    ]
  }
}
